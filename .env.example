# ── Firebase (시그널링 + 룸) — Netlify 배포 시 필수 ────────────
# Firebase 콘솔 → 프로젝트 설정 → 일반 → "내 앱"(웹) → SDK 설정에서 복사
# ⚠️ Realtime Database를 반드시 생성해야 databaseURL이 나옵니다.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_DATABASE_URL=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ── 앱 URL (PWA, 딥링크, QR) ──────────────────────────────────
# 배포 후 Netlify 주소로 교체 (예: https://mirroron.netlify.app)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── TURN (선택) ──────────────────────────────────────────────
# 미설정이어도 공개 openrelay 릴레이가 자동 사용됨. 대규모 시 전용 키 입력.
TURN_API_KEY=
TURN_APP_NAME=mirroron

# ── 로컬 개발 전용 ────────────────────────────────────────────
# Firebase 값이 없으면 인메모리 데브 모드로 폴백. 아래는 그때만 의미 있음.
IP_SALT=mirroron-dev

# ── Supabase (레거시 — Firebase로 대체됨, 비워두세요) ─────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
